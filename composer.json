{
    "name": "joelstein/blade-formatter",
    "description": "Format Blade templates and Livewire SFCs with Pint, Tailwind class sorting, and auto-indentation",
    "keywords": ["laravel", "blade", "livewire", "formatter", "pint", "tailwind"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/pint": "^1.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "bin": ["bin/blade-format"],
    "autoload": {
        "psr-4": {
            "JoelStein\\BladeFormatter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JoelStein\\BladeFormatter\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JoelStein\\BladeFormatter\\BladeFormatterServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
