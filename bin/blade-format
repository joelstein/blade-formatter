#!/usr/bin/env php
<?php

$autoloadPaths = [
    __DIR__.'/../vendor/autoload.php',       // When run from package root
    __DIR__.'/../../../autoload.php',         // When installed as a dependency
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        define('COMPOSER_AUTOLOAD', $autoloadPath);
        break;
    }
}

if (! defined('COMPOSER_AUTOLOAD')) {
    fwrite(STDERR, "Could not find Composer autoloader. Run 'composer install' first.\n");
    exit(1);
}

require COMPOSER_AUTOLOAD;

$app = require __DIR__.'/../bootstrap/app.php';

$kernel = $app->make(Illuminate\Contracts\Console\Kernel::class);

$status = $kernel->handle(
    $input = new Symfony\Component\Console\Input\ArgvInput,
    new Symfony\Component\Console\Output\ConsoleOutput
);

$kernel->terminate($input, $status);

exit($status);
